# Copy to backend/.env and adjust for your environment.

ENVIRONMENT=development

# Required in production — generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

DATABASE_URL=postgresql+asyncpg://erp:erp@localhost:5432/erp

# Bootstrap admin (change before deploying)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# Shared password for scripts/seed_rbac_users.py (50 dev test users)
SEED_USER_PASSWORD=SeedUser123!

# Set to false for an empty ERP after scripts/clear_database.py (no auto demo BOM/garment/modules).
SEED_DEMO_DATA=true

ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional agentic AI (OpenAI-compatible)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# Required in production when LLM_BASE_URL is set — comma-separated hostname allowlist
LLM_ALLOWED_HOSTS=
